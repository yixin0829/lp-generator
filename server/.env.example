# Runtime environment: local | development | test | production
APP_ENV=development

# API
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-mini
MAX_TOPIC_LENGTH=30

# Security
REQUIRE_API_KEY=false
API_KEY=your-backend-api-key

# Rate limiting
RATE_LIMIT_ENABLED=true
LP_RATE_LIMIT=15/minute
STATS_RATE_LIMIT=30/minute

# Counter backend: noop | firestore
COUNTER_BACKEND=noop
FIRESTORE_COUNTER_COLLECTION=stats
FIRESTORE_COUNTER_DOCUMENT=learning_paths
FIRESTORE_COUNTER_FIELD=generated_count
